# MongoDB & General
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=password123
MONGO_AUTH_DB=admin

# MongoDB Database Names (one per Medallion layer)
MONGO_DB_BRONZE=tlc_bronze
MONGO_DB_SILVER=tlc_silver
MONGO_DB_GOLD=tlc_gold
MONGO_DB_AUDIT=tlc_audit

# TLC Data Source
TLC_DATA_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
TLC_LOOKUP_URL=https://d37ci6vzurychx.cloudfront.net/misc

# Project Paths (inside container)
PROJECT_ROOT=/home/jovyan/work
DATA_DIR=/home/jovyan/work/data

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_EXECUTOR_MEMORY=4g
SPARK_DRIVER_MEMORY=4g

# Logging
LOG_LEVEL=INFO

# Kafka (Phase 2 — Streaming)
# Internal address used by Spark Streaming Consumer (inside Docker network)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_YELLOW_2026=tlc-yellow-2026
KAFKA_TOPIC_GREEN_2026=tlc-green-2026